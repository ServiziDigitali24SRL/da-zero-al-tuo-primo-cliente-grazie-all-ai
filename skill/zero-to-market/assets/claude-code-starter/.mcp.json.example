{
  "_commento": "Copia in .mcp.json SOLO i server che servono a questo progetto. Ogni server aggiunto invalida la cache globale del system prompt e costa contesto: non collegarli tutti.",
  "_segreti": "Mai valori letterali. Usa ${VAR}: vengono espansi dall'environment quando Claude Code avvia il server.",
  "mcpServers": {
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp"
    },
    "stripe": {
      "type": "http",
      "url": "https://mcp.stripe.com"
    },
    "vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com"
    },
    "netlify": {
      "type": "http",
      "url": "https://netlify-mcp.netlify.app/mcp"
    },
    "linear": {
      "type": "http",
      "url": "https://mcp.linear.app/mcp"
    },
    "notion": {
      "type": "http",
      "url": "https://mcp.notion.com/mcp"
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "sentry": {
      "type": "http",
      "url": "https://mcp.sentry.dev/mcp"
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": { "GITHUB_TOKEN": "${GITHUB_TOKEN}" }
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "${DATABASE_URL}"]
    }
  }
}
